# ── ローカル開発用 (.env.local にコピーして使用) ─────────────
# Supabase の接続文字列 (Settings → Database → URI)
# サーバーレス環境では PgBouncer 経由 (port 6543) を推奨
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# JWT 署名シークレット (32文字以上のランダム文字列)
JWT_SECRET=change_me_to_a_long_random_secret
